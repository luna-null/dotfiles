### Idle configuration
#
# Example configuration:

set $lock swaylock -f -i /home/le/Pictures/background-images/lockscreen.jpg 
exec swayidle -w \
        timeout 300 $lock \
        timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
        before-sleep $lock
#
# This will lock your screen after 300 seconds of inactivity, then turn off
# your displays after another 300 seconds, and turn your screens back on when
# resumed. It will also lock your screen before your computer goes to sleep.

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:DejaVuSansM Nerd Font Mono 11
#font pango:DejaVuSansMono Nerd Font 11
font pango:FiraCode Nerd Font, FontAwesome, 11



### Variables - this file is mostly these
# Logo key. Use Mod1 for Alt.
set $mod Mod4
set $alt Mod1

# Directory to custom Scripts
set $BIN_DIR ~/.local/bin/sway

